    },
    "steel-gray": {
      "$value": "#e3e4e8",
      "$type": "color",
      "$description": "Steel Gray — Subtle borders and separators, defining boundaries without starkness."
    },
    "charcoal-text": {
      "$value": "#232730",
      "$type": "color",
      "$description": "Charcoal Text — Text on lighter backgrounds for softer contrast than pure black, often used in navigation and body text."
    },
    "slate-text": {
      "$value": "#7c7f88",
      "$type": "color",
      "$description": "Slate Text — Contextual body text and secondary labels, offering readability without competing with primary elements."
    },
    "graphite": {
      "$value": "#12161",
      "$type": "color",
      "$description": "Graphite — Darker shades for text and icons, particularly on hero sections, for depth."
    },
