  "font": {
    "suisseintl": {
      "$value": "SuisseIntl",
      "$type": "fontFamily",
      "$description": "Primary typeface for all main content, headings, and UI elements. Its clean, slightly compressed letterforms convey efficiency and sophistication. Weight 600 at 48px headlines commands attention with quiet confidence; weight 300 for subheadings at 28px adds a subtle, approachable gravity. The variable letter-spacing (up to -0.03em at larger sizes) tightens display text for visual impact."
    },
    "sfmono": {
      "$value": "SFMono",
      "$type": "fontFamily",
      "$description": "Monospaced font for code snippets, financial figures, and technical labels, ensuring precise alignment and clarity for data-driven content. Its consistent width emphasizes the accuracy inherent in banking operations."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Secondary typeface, primarily for detailed body text and supporting UI elements. Provides similar legibility to SuisseIntl but with slightly more open letterforms at smaller sizes, aiding readability in high-information densities."
    },
    "suisseintlmono": {
      "$value": "SuisseIntlMono",
      "$type": "fontFamily",
      "$description": "Specialized monospaced font for technical outputs and code display within the UI, complementing SFMono for specific interactive code contexts. Its presence reinforces the developer-centric aspect of Column."
    }
  },
