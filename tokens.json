      "$value": "#111a4a",
      "$type": "color",
      "$description": "Deep Plum — Brand accent for interactive elements, icons, and significant textual highlights, establishing Column's brand identity."
    },
    "action-orange": {
      "$value": "#ec652b",
      "$type": "color",
